# Copy this file to .env before running `docker compose up`.
# .env is gitignored — never commit real secrets.

POSTGRES_USER=taskuser
POSTGRES_PASSWORD=taskpass
POSTGRES_DB=taskdb
POSTGRES_PORT=5432

BACKEND_PORT=8090
FRONTEND_PORT=8081

# Used only by the Jenkinsfile / prod compose file, not by local dev.
DOCKERHUB_NAMESPACE=lalbudha47
IMAGE_TAG=latest
